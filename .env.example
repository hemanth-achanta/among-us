# ─────────────────────────────────────────────────────────────────────────────
# Analytics Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
# Supported values: postgresql | mysql | snowflake
DATABASE_TYPE=postgresql

DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_SCHEMA=public

# Snowflake-specific (leave blank for PostgreSQL/MySQL)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=

# ── Connection Pooling ────────────────────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── LLM Models ────────────────────────────────────────────────────────────────
LOW_MODEL=claude-haiku-4-5-20251001
MEDIUM_MODEL=claude-sonnet-4-6
HIGH_MODEL=claude-sonnet-4-6

# ── Orchestrator Tuning ───────────────────────────────────────────────────────
MAX_QUERY_ITERATIONS=3
MAX_RETRIES=3
RETRY_ESCALATION_THRESHOLD=2
MIN_CONFIDENCE_THRESHOLD=0.6
RETRY_ON_EMPTY_RESULT=true

# ── Schema Context ────────────────────────────────────────────────────────────
SCHEMA_CONTEXT_TOKEN_LIMIT=3000
SCHEMA_SAMPLE_ROWS=3

# ── LLM Behaviour ─────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.0
LLM_REQUEST_TIMEOUT=60

# ── Results ───────────────────────────────────────────────────────────────────
MAX_RESULT_ROWS=500

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# json | text
LOG_FORMAT=json

# ── UI ────────────────────────────────────────────────────────────────────────
# Set to true to show SQL, model, iterations in the UI by default
SHOW_DEBUG_INFO=false
